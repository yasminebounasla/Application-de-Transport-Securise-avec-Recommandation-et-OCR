# Copier ce fichier en .env et modifier les valeurs selon vos besoins

# Modèle Insightface 
MODEL_PACK=buffalo_l
DET_SIZE=[640,640]
CTX_ID=0  # -1 for CPU, 0 for GPU (if you have NVIDIA CUDA)

# API Configuration 
API_HOST=0.0.0.0
API_PORT=8002
API_TITLE=Face Recognition Service
API_VERSION=1.0.0

# Chemins de Données
DATA_DIR=data
LICENSE_DIR=data/license_images
SELFIE_DIR=data/selfie_images
OUTPUT_DIR=outputs

# Logging
LOG_LEVEL=INFO
