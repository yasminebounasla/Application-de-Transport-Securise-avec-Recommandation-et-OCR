# Copier ce fichier en .env et modifier les valeurs

FLASK_PORT=5001


# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# OCR Configuration (Utiliser GPU si disponible [true if you have NVIDIA CUDA - false otherswise])
USE_GPU=false

# Langues OCR
OCR_LANGUAGES=en,fr

# Timeout OCR en secondes
OCR_TIMEOUT=30

# Upload Configuration
MAX_UPLOAD_SIZE=10

# Extensions autorisées
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp

# Storage Configuration (Dossier de sortie pour les résultats)
OUTPUT_DIR=outputs

# Dossier temporaire pour les uploads
TEMP_DIR=temp

# Conserver les fichiers temporaires (true/false)
KEEP_TEMP_FILES=false

# Securité (Clé Secrète API - Use: python -c "import secrets; print(secrets.token_hex(32))")
API_SECRET_KEY=change-this-in-production-to-random-secret-key

# CORS Origins autorisées (* pour tous)
CORS_ORIGINS=*

# LOGGING (Niveaux de log: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Fichier de log
LOG_FILE=app.log

# Processing (Nombre maximum d'images en batch)
MAX_BATCH_SIZE=10

# Rotation automatique (true/false)
AUTO_ROTATION=true

# DATABASE (Optionnel - si besoin futur)
# DATABASE_URL=sqlite:///./ocr_database.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# REDIS (Optionnel - pour cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
